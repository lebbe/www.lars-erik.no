---
import type { IconNode } from 'lucide'

interface Props {
  icon: IconNode
  size?: number
  class?: string
}

const { icon, size = 24, class: className } = Astro.props
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
>
  {
    icon.map(([tag, attrs]) => {
      const El = tag as any
      return <El {...attrs} />
    })
  }
</svg>
